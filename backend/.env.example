# ==============================================================================
# LifeOS Backend Configuration Template
# Copy this file to '.env' in this directory for running backend services locally.
# ==============================================================================

# Core FastAPI Configuration
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-secure-secret-key-for-local-development
PROJECT_NAME="LifeOS AI Backend"

# Database Configuration (PostgreSQL)
POSTGRES_USER=lifeos_user
POSTGRES_PASSWORD=lifeos_secure_password_123
POSTGRES_DB=lifeos_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lifeos_user:lifeos_secure_password_123@localhost:5432/lifeos_db

# Cache & Message Broker (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# AI Integration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
