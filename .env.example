# ==============================================================================
# LifeOS AI - Environment Variables Template
# Copy this file to '.env' at the repository root and adjust values as needed.
# NEVER commit the actual '.env' file to Git control.
# ==============================================================================

# Core App Settings
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-secure-secret-key-for-local-development

# Backend Service Configs
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Database Configuration (PostgreSQL)
POSTGRES_USER=lifeos_user
POSTGRES_PASSWORD=lifeos_secure_password_123
POSTGRES_DB=lifeos_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://lifeos_user:lifeos_secure_password_123@localhost:5432/lifeos_db

# Cache & Message Broker (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# AI Engines & Providers
# Initialize with Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Frontend Service Configs
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
